{% comment %}
  Cart page preview for custom line art.
  Paste this into a Custom Liquid block on the cart page, not the product page.
{% endcomment %}

{% assign line_art_preview_count = 0 %}
{% capture line_art_previews %}
  {% for item in cart.items %}
    {% assign design_preview = item.properties['Design Preview'] %}
    {% assign design_id = item.properties['Design ID'] %}
    {% if design_preview != blank %}
      {% assign line_art_preview_count = line_art_preview_count | plus: 1 %}
      <div class="line-art-cart-card">
        <div class="line-art-cart-image-wrap">
          <img src="{{ design_preview | escape }}" alt="{{ item.product.title | escape }} custom line art">
        </div>
        <div class="line-art-cart-details">
          <div class="line-art-cart-title">{{ item.product.title }}</div>
          {% if design_id != blank %}
            <div class="line-art-cart-meta">Design ID: {{ design_id }}</div>
          {% endif %}
          {% if item.properties['Ink Color'] != blank %}
            <div class="line-art-cart-meta">Ink: {{ item.properties['Ink Color'] }}</div>
          {% endif %}
          {% if item.properties['Stamp Size'] != blank %}
            <div class="line-art-cart-meta">Size: {{ item.properties['Stamp Size'] }}</div>
          {% endif %}
          {% if item.properties['Above Text'] != blank %}
            <div class="line-art-cart-meta">Above: {{ item.properties['Above Text'] }}</div>
          {% endif %}
          {% if item.properties['Below Text'] != blank %}
            <div class="line-art-cart-meta">Below: {{ item.properties['Below Text'] }}</div>
          {% endif %}
        </div>
      </div>
    {% endif %}
  {% endfor %}
{% endcapture %}

{% if line_art_preview_count > 0 %}
  <style>
    .line-art-cart-preview {
      margin: 24px 0;
      padding: 18px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      background: #ffffff;
      font-family: inherit;
    }

    .line-art-cart-heading {
      margin: 0 0 14px;
      font-size: 18px;
      font-weight: 700;
      color: #111827;
    }

    .line-art-cart-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 14px;
    }

    .line-art-cart-card {
      display: grid;
      grid-template-columns: 88px 1fr;
      gap: 12px;
      align-items: center;
      min-width: 0;
      padding: 12px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      background: #f9fafb;
    }

    .line-art-cart-image-wrap {
      width: 88px;
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      background: #ffffff;
      overflow: hidden;
    }

    .line-art-cart-image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }

    .line-art-cart-title {
      font-size: 14px;
      font-weight: 700;
      line-height: 1.3;
      color: #111827;
    }

    .line-art-cart-meta {
      margin-top: 4px;
      font-size: 12px;
      line-height: 1.35;
      color: #4b5563;
      overflow-wrap: anywhere;
    }

    @media (max-width: 520px) {
      .line-art-cart-preview {
        padding: 14px;
      }

      .line-art-cart-grid {
        grid-template-columns: 1fr;
      }

      .line-art-cart-card {
        grid-template-columns: 76px 1fr;
        padding: 10px;
      }

      .line-art-cart-image-wrap {
        width: 76px;
      }
    }
  </style>

  <div class="line-art-cart-preview">
    <h2 class="line-art-cart-heading">Your Custom Line Art</h2>
    <div class="line-art-cart-grid">
      {{ line_art_previews }}
    </div>
  </div>
{% endif %}
