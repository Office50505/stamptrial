{% comment %}
  Cart page preview for custom line art.
  Paste this into a Custom Liquid block on the cart page, not the product page.
{% endcomment %}

{% assign line_art_preview_count = 0 %}
{% capture line_art_previews %}
  {% for item in cart.items %}
    {% assign design_preview = item.properties['_Design Preview'] %}
    {% if design_preview == blank %}
      {% assign design_preview = item.properties['Design Preview'] %}
    {% endif %}

    {% assign stamp_color = item.properties['Stamp Color'] %}
    {% if stamp_color == blank %}
      {% assign stamp_color = item.properties['Ink Color'] %}
    {% endif %}

    {% assign stamp_size = item.properties['Stamp Size'] %}

    {% assign top_text = item.properties['Top Text'] %}
    {% if top_text == blank %}
      {% assign top_text = item.properties['Above Text'] %}
    {% endif %}

    {% assign bottom_text = item.properties['Bottom Text'] %}
    {% if bottom_text == blank %}
      {% assign bottom_text = item.properties['Below Text'] %}
    {% endif %}

    {% assign design_notes = item.properties['Design Notes'] %}
    {% if design_notes == blank %}
      {% assign design_notes = item.properties['Notes For Designer'] %}
    {% endif %}

    {% if design_preview != blank or stamp_color != blank or stamp_size != blank or top_text != blank or bottom_text != blank or design_notes != blank %}
      {% assign line_art_preview_count = line_art_preview_count | plus: 1 %}
      <article class="line-art-cart-card{% if design_preview == blank %} line-art-cart-card--no-image{% endif %}">
        {% if design_preview != blank %}
          <a class="line-art-cart-image-wrap" href="{{ design_preview | escape }}" target="_blank" rel="noopener">
            <img src="{{ design_preview | escape }}" alt="{{ item.product.title | escape }} custom stamp preview">
          </a>
        {% endif %}

        <div class="line-art-cart-details">
          <div class="line-art-cart-kicker">Custom stamp design</div>
          <div class="line-art-cart-title">{{ item.product.title | escape }}</div>

          <dl class="line-art-cart-list">
            {% if stamp_color != blank %}
              <div><dt>Stamp Color</dt><dd>{{ stamp_color | capitalize | escape }}</dd></div>
            {% endif %}
            {% if stamp_size != blank %}
              <div><dt>Size</dt><dd>{{ stamp_size | escape }}</dd></div>
            {% endif %}
            {% if top_text != blank %}
              <div><dt>Top Text</dt><dd>{{ top_text | escape }}</dd></div>
            {% endif %}
            {% if bottom_text != blank %}
              <div><dt>Bottom Text</dt><dd>{{ bottom_text | escape }}</dd></div>
            {% endif %}
          </dl>

          {% if design_notes != blank %}
            <div class="line-art-cart-notes">
              <span>Design Notes</span>
              <p>{{ design_notes | escape }}</p>
            </div>
          {% endif %}
        </div>
      </article>
    {% endif %}
  {% endfor %}
{% endcapture %}

{% if line_art_preview_count > 0 %}
  <style>
    .line-art-cart-preview {
      container: line-art-cart-preview / inline-size;
      box-sizing: border-box;
      max-width: 100%;
      margin: 24px 0;
      padding: 18px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      background: #ffffff;
      font-family: inherit;
    }

    .line-art-cart-heading {
      margin: 0;
      font-size: 18px;
      font-weight: 750;
      color: #111827;
    }

    .line-art-cart-subheading {
      margin: 4px 0 16px;
      font-size: 13px;
      line-height: 1.45;
      color: #6b7280;
    }

    .line-art-cart-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .line-art-cart-card {
      box-sizing: border-box;
      display: grid;
      grid-template-columns: 112px minmax(0, 1fr);
      gap: 14px;
      align-items: start;
      min-width: 0;
      padding: 14px;
      border: 1px solid #e5e7eb;
      border-radius: 8px;
      background: #f9fafb;
    }

    .line-art-cart-details {
      min-width: 0;
    }

    .line-art-cart-card--no-image {
      grid-template-columns: 1fr;
    }

    .line-art-cart-card--no-image .line-art-cart-details {
      grid-column: 1 / -1;
    }

    .line-art-cart-image-wrap {
      box-sizing: border-box;
      width: 112px;
      aspect-ratio: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px solid #d1d5db;
      border-radius: 8px;
      background: #ffffff;
      overflow: hidden;
    }

    .line-art-cart-image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
    }

    .line-art-cart-kicker {
      margin-bottom: 3px;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0;
      text-transform: uppercase;
      color: #2f7dee;
    }

    .line-art-cart-title {
      margin-bottom: 10px;
      font-size: 15px;
      font-weight: 750;
      line-height: 1.3;
      color: #111827;
    }

    .line-art-cart-list {
      margin: 0;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    .line-art-cart-list div {
      min-width: 0;
      padding: 8px 10px;
      border: 1px solid #e5e7eb;
      border-radius: 6px;
      background: #ffffff;
    }

    .line-art-cart-list dt {
      margin: 0 0 2px;
      font-size: 10px;
      font-weight: 800;
      color: #6b7280;
      text-transform: uppercase;
    }

    .line-art-cart-list dd {
      margin: 0;
      font-size: 12px;
      line-height: 1.35;
      color: #111827;
      overflow-wrap: anywhere;
    }

    .line-art-cart-notes {
      margin-top: 10px;
      padding: 10px;
      border: 1px solid #dbeafe;
      border-radius: 6px;
      background: #eff6ff;
    }

    .line-art-cart-notes span {
      display: block;
      margin-bottom: 4px;
      font-size: 10px;
      font-weight: 800;
      color: #1d4ed8;
      text-transform: uppercase;
    }

    .line-art-cart-notes p {
      margin: 0;
      font-size: 12px;
      line-height: 1.45;
      color: #1f2937;
      overflow-wrap: anywhere;
    }

    @media (max-width: 620px) {
      .line-art-cart-preview {
        margin: 14px 0;
        padding: 12px;
      }

      .line-art-cart-heading {
        font-size: 16px;
      }

      .line-art-cart-subheading {
        display: none;
      }

      .line-art-cart-card {
        grid-template-columns: 88px minmax(0, 1fr);
        gap: 10px;
        padding: 10px;
      }

      .line-art-cart-image-wrap {
        width: 88px;
      }

      .line-art-cart-list {
        grid-template-columns: 1fr;
        gap: 4px;
      }

      .line-art-cart-list div {
        display: grid;
        grid-template-columns: 76px minmax(0, 1fr);
        gap: 6px;
        align-items: baseline;
        padding: 0;
        border: 0;
        background: transparent;
      }

      .line-art-cart-list dt {
        margin: 0;
        font-size: 10px;
      }

      .line-art-cart-list dd {
        font-size: 12px;
        line-height: 1.25;
      }

      .line-art-cart-notes {
        display: grid;
        grid-template-columns: 76px minmax(0, 1fr);
        gap: 6px;
        margin-top: 4px;
        padding: 0;
        border: 0;
        background: transparent;
      }

      .line-art-cart-notes span {
        margin: 0;
        color: #6b7280;
      }

      .line-art-cart-notes p {
        font-size: 12px;
        line-height: 1.3;
      }
    }

    @container line-art-cart-preview (max-width: 620px) {
      .line-art-cart-heading {
        font-size: 16px;
      }

      .line-art-cart-subheading {
        display: none;
      }

      .line-art-cart-card {
        gap: 10px;
        padding: 10px;
      }

      .line-art-cart-list {
        grid-template-columns: 1fr;
        gap: 4px;
      }

      .line-art-cart-list div {
        display: grid;
        grid-template-columns: 76px minmax(0, 1fr);
        gap: 6px;
        align-items: baseline;
        padding: 0;
        border: 0;
        background: transparent;
      }

      .line-art-cart-list dt {
        margin: 0;
        font-size: 10px;
      }

      .line-art-cart-list dd {
        font-size: 12px;
        line-height: 1.25;
      }

      .line-art-cart-notes {
        display: grid;
        grid-template-columns: 76px minmax(0, 1fr);
        gap: 6px;
        margin-top: 4px;
        padding: 0;
        border: 0;
        background: transparent;
      }

      .line-art-cart-notes span {
        margin: 0;
        color: #6b7280;
      }

      .line-art-cart-notes p {
        font-size: 12px;
        line-height: 1.3;
      }
    }

    @media (max-width: 420px) {
      .line-art-cart-card {
        grid-template-columns: 74px minmax(0, 1fr);
        gap: 10px;
        padding: 10px;
      }

      .line-art-cart-image-wrap {
        width: 74px;
      }

      .line-art-cart-list {
        grid-template-columns: 1fr;
      }

      .line-art-cart-title {
        font-size: 14px;
        margin-bottom: 6px;
      }

      .line-art-cart-card--no-image {
        grid-template-columns: 1fr;
      }
    }

    @container line-art-cart-preview (max-width: 420px) {
      .line-art-cart-card {
        grid-template-columns: 74px minmax(0, 1fr);
        gap: 10px;
        padding: 10px;
      }

      .line-art-cart-image-wrap {
        width: 74px;
      }

      .line-art-cart-list {
        grid-template-columns: 1fr;
      }

      .line-art-cart-title {
        font-size: 14px;
        margin-bottom: 6px;
      }

      .line-art-cart-card--no-image {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 300px) {
      .line-art-cart-preview {
        padding: 12px;
      }

      .line-art-cart-card {
        grid-template-columns: 64px minmax(0, 1fr);
        padding: 10px;
      }

      .line-art-cart-image-wrap {
        width: 64px;
      }

      .line-art-cart-card--no-image {
        grid-template-columns: 1fr;
      }
    }

    @container line-art-cart-preview (max-width: 300px) {
      .line-art-cart-card {
        grid-template-columns: 64px minmax(0, 1fr);
        padding: 10px;
      }

      .line-art-cart-image-wrap {
        width: 64px;
      }

      .line-art-cart-card--no-image {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <section class="line-art-cart-preview" aria-label="Custom stamp design summary">
    <h2 class="line-art-cart-heading">Custom Design Summary</h2>
    <p class="line-art-cart-subheading">Review the saved stamp artwork and personalization details before checkout.</p>
    <div class="line-art-cart-grid">
      {{ line_art_previews }}
    </div>
  </section>
{% endif %}
